# Виртуальный офис трейдера — переменные окружения
# Скопируй в .env и заполни реальными ключами

# ── Claude / Anthropic ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-opus-4-6

# ── TraderMake.Money ──────────────────────────────────────────────────
TTM_API_KEY=your-ttm-api-key
TTM_BASE_URL=https://tradermake.money/api/v2

# ── ElevenLabs TTS ────────────────────────────────────────────────────
ELEVENLABS_API_KEY=your-elevenlabs-key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Services ──────────────────────────────────────────────────────────
WHISPER_BASE_URL=http://whisper-api:8001
REDIS_URL=redis://redis:6379/0

# ── Risk / Trade deposit ──────────────────────────────────────────────
TRADE_DEPOSIT=1000.0
RISK_FAR_BELOW_MPP_THRESHOLD=3.0

# ── API ───────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8002
